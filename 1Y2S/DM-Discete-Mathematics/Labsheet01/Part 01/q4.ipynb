   "source": [
    "4. Write a Python program using a for loop to enter marks for 5 subjects and calculate the \n",
    "total marks.  "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "28e3b78f",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Total marks :  345.0\n"
     ]
    }
   ],
   "source": [
    "total = 0.0\n",
    "for i in range (1,6):\n",
    "    marks = float(input(\"Enter marks : \"))\n",
    "    total += marks\n",
    "print(\"Total marks : \", total)\n"
   ]
  }
